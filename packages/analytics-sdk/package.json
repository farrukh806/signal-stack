{
  "name": "@analytics/sdk",
  "version": "1.0.0",
  "description": "Lightweight JavaScript analytics SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs",
      "types": "./dist/browser.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit"
  },
  "keywords": ["analytics", "tracking", "sdk"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}